<Window x:Class="MossadStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="Mossad Studio" Height="400" Width="700" MinWidth="700" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="CanResize" AllowsTransparency="True" Background="Transparent"
        FontFamily="Segoe UI" FontSize="12">
    <Window.Resources>
        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="#1a1a1a"/>
            <Setter Property="Foreground" Value="#dddddd"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ItemsPresenter Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="#dddddd"/>
            <Setter Property="Padding" Value="20,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd" Padding="{TemplateBinding Padding}" Background="Transparent" BorderThickness="0">
                            <ContentPresenter ContentSource="Header" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#252525" />
                                <Setter Property="Foreground" Value="#3ea0f0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30" CornerRadius="0" GlassFrameThickness="0" ResizeBorderThickness="4" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <!-- Outer container: almost pure black, with the blue top border -->
    <Border Background="#121212" BorderBrush="#000000" BorderThickness="1">
        <Border BorderBrush="#3ea0f0" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" /> <!-- Title Bar -->
                    <RowDefinition Height="25" /> <!-- Menu Bar -->
                    <RowDefinition Height="*" /> <!-- Workspace Container -->
                </Grid.RowDefinitions>

                <!-- 1. Title bar -->
                <Grid Grid.Row="0">
                    <Image Source="pack://application:,,,/icon.ico" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0,0,0" Width="16" Height="16" RenderOptions.BitmapScalingMode="HighQuality" />
                    <!-- Centered exactly in window -->
                    <TextBlock Text="Mossad Studio" Foreground="#cccccc" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Width="35" Background="Transparent" Foreground="#cccccc" BorderThickness="0" Content="—" Click="Minimize_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#333333"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Width="35" Background="Transparent" Foreground="#cccccc" BorderThickness="0" Content="✕" Click="Close_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#e81123"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- 2. Menubar -->
                <Grid Grid.Row="1">
                    <StackPanel Orientation="Horizontal" Margin="8,0,0,0">
                        <TextBlock Text="File" Foreground="#dddddd" Margin="0,0,15,0" VerticalAlignment="Center" Cursor="Hand" MouseLeftButtonDown="TopMenu_LeftClick">
                            <TextBlock.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Open File" Click="BtnOpenFile_Click" />
                                    <MenuItem Header="Save File" Click="BtnSaveFile_Click" />
                                    <MenuItem Header="Execute File" Click="BtnExecute_Click" />
                                    <Separator Background="#222222" Margin="0,2" />
                                    <MenuItem Header="Undo" Click="BtnUndo_Click" />
                                    <MenuItem Header="Redo" Click="BtnRedo_Click" />
                                    <Separator Background="#222222" Margin="0,2" />
                                    <MenuItem Header="Find &amp; Replace" Click="BtnFindReplace_Click" />
                                </ContextMenu>
                            </TextBlock.ContextMenu>
                        </TextBlock>
                        
                        <TextBlock Text="Credits" Foreground="#dddddd" Margin="0,0,15,0" VerticalAlignment="Center" Cursor="Hand" MouseLeftButtonDown="TopMenu_CreditsClick" />
                        
                        <TextBlock Text="Games" Foreground="#dddddd" Margin="0,0,15,0" VerticalAlignment="Center" Cursor="Hand" MouseLeftButtonDown="TopMenu_GamesClick" />
                        
                        <TextBlock Text="Hot-Scripts" Foreground="#dddddd" Margin="0,0,15,0" VerticalAlignment="Center" Cursor="Hand" MouseLeftButtonDown="TopMenu_LeftClick">
                            <TextBlock.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Infinite Yield" Click="BtnHotScript_InfiniteYield" />
                                    <MenuItem Header="Dex Explorer" Click="BtnHotScript_Dex" />
                                    <MenuItem Header="OwlHub" Click="BtnHotScript_OwlHub" />
                                    <Separator Background="#222222" Margin="0,2" />
                                    <MenuItem Header="UNC Environment Test" Click="BtnHotScript_UNC" />
                                    <MenuItem Header="SimpleSpy v3" Click="BtnHotScript_SimpleSpy" />
                                    <MenuItem Header="Unnamed ESP" Click="BtnHotScript_UnnamedESP" />
                                </ContextMenu>
                            </TextBlock.ContextMenu>
                        </TextBlock>
                        
                        <TextBlock Text="Others" Foreground="#dddddd" Margin="0,0,15,0" VerticalAlignment="Center" Cursor="Hand" MouseLeftButtonDown="TopMenu_LeftClick">
                            <TextBlock.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Go to SirHurt Dashboard" Click="BtnOthers_Dashboard" />
                                    <MenuItem Header="Join Discord Server" Click="BtnOthers_Discord" />
                                </ContextMenu>
                            </TextBlock.ContextMenu>
                        </TextBlock>
                    </StackPanel>
                </Grid>

                <!-- Workspace Container to enforce the padding and absolute layout inside -->
                <Grid Grid.Row="2" Margin="3,3,3,3">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" /> <!-- Tabs/Editor and Panel -->
                        <RowDefinition Height="Auto" /> <!-- Bottom Action Buttons -->
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="150" /> <!-- Right Panel Space -->
                        </Grid.ColumnDefinitions>

                        <!-- Left Side: Tabs + Editor -->
                        <Grid Grid.Column="0">
                            <Grid.Resources>
                                <Style TargetType="TabControl">
                                    <Setter Property="Background" Value="#222222" />
                                    <Setter Property="BorderBrush" Value="#000000" />
                                    <Setter Property="BorderThickness" Value="1,1,0,1" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TabControl">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="*" />
                                                    </Grid.RowDefinitions>
                                                    <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TabPanel x:Name="HeaderPanel" IsItemsHost="true" Margin="0,0,-1,0" />
                                                            <TextBlock Text="+" Foreground="#cccccc" FontSize="16" Margin="10,-2,10,0" VerticalAlignment="Center" FontWeight="Bold" Cursor="Hand" MouseLeftButtonDown="AddTabButton_Click" />
                                                        </StackPanel>
                                                    </ScrollViewer>
                                                    <Border Grid.Row="1" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                                        <ContentPresenter x:Name="PART_SelectedContentHost" ContentSource="SelectedContent" Margin="{TemplateBinding Padding}" />
                                                    </Border>
                                                </Grid>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                                <Style TargetType="TabItem">
                                    <Setter Property="Background" Value="#181818" />
                                    <Setter Property="Foreground" Value="#cccccc" />
                                    <Setter Property="FontFamily" Value="Segoe UI" />
                                    <Setter Property="FontSize" Value="11" />
                                    <Setter Property="Padding" Value="5,0" />
                                    <Setter Property="Height" Value="22" />
                                    <Setter Property="BorderThickness" Value="1,1,1,0" />
                                    <Setter Property="BorderBrush" Value="#000000" />
                                    <Setter Property="Margin" Value="0,0,-1,0" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TabItem">
                                                <Border Name="Border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Margin="{TemplateBinding Margin}">
                                                    <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center" ContentSource="Header" Margin="{TemplateBinding Padding}" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="#252525" />
                                                        <Setter TargetName="Border" Property="Margin" Value="-1,-1,-1,0" />
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="#202020" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Grid.Resources>
                            
                            <!-- Tab header background layer -->
                            <Border Background="#1c1c1c" VerticalAlignment="Top" Height="22" />
                            
                            <TabControl x:Name="EditorTabs" />
                        </Grid>

                        <!-- Right Side Panel -->
                        <Border Grid.Column="1" Background="#181818" BorderBrush="#000000" BorderThickness="1">
                            <TreeView Name="ScriptsTreeView" Background="Transparent" BorderThickness="0" Foreground="#cccccc" Margin="2" MouseDoubleClick="ScriptsTreeView_MouseDoubleClick">
                                <TreeView.Resources>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="Foreground" Value="#cccccc" />
                                    </Style>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3a3a3a"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#3a3a3a"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White"/>
                                </TreeView.Resources>
                            </TreeView>
                        </Border>
                    </Grid>

                    <!-- Bottom Buttons -->
                    <Grid Grid.Row="1" Margin="0,2,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid.Resources>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#252525"/>
                                <Setter Property="Foreground" Value="#cccccc"/>
                                <Setter Property="BorderThickness" Value="1,0,1,0"/>
                                <Setter Property="BorderBrush" Value="#000000"/>
                                <Setter Property="Padding" Value="25,4"/>
                                <Setter Property="Margin" Value="0,0,-1,0"/> <!-- Collapse left/right duplicate borders -->
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#303030"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter Property="Background" Value="#101010"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Grid.Resources>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" Background="#121212">
                            <Button Name="BtnExecute" Content="EXECUTE" BorderThickness="1,1,1,1" Margin="0" Click="BtnExecute_Click" />
                            <Button Name="BtnClear" Content="CLEAR" BorderThickness="0,1,1,1" Margin="0" Click="BtnClear_Click"/>
                            <Button Content="OPEN FILE" BorderThickness="0,1,1,1" Margin="0" Click="BtnOpenFile_Click" />
                            <Button Content="SAVE FILE" BorderThickness="0,1,1,1" Margin="0" Click="BtnSaveFile_Click" />
                            <Button Name="BtnInject" Content="INJECT" BorderThickness="0,1,1,1" Margin="0" Click="BtnInject_Click"/>
                        </StackPanel>

                        <!-- The Options button aligned right, matching the right panel boundary -->
                        <Button Name="BtnOptions" Grid.Column="1" Content="OPTIONS" BorderThickness="1,1,1,1" Margin="0" Click="BtnOptions_Click" />
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
