<Window x:Class="MossadStudio.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="400" Width="280"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True" Background="Transparent"
        FontFamily="Segoe UI" FontSize="12">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30" CornerRadius="0" GlassFrameThickness="0" ResizeBorderThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Toggle Switch Style -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#dddddd"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <ContentPresenter Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,0,10,0"/>

                            <!-- The Track -->
                            <Border Grid.Column="1" x:Name="Track" Width="36" Height="18" CornerRadius="9" Background="#333333" BorderBrush="#000000" BorderThickness="1" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0">
                                <!-- The Handle -->
                                <Ellipse x:Name="Handle" Width="14" Height="14" Fill="#aaaaaa" HorizontalAlignment="Left" Margin="2,0,0,0">
                                    <Ellipse.RenderTransform>
                                        <TranslateTransform x:Name="HandleTransform" X="0" />
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#3ea0f0"/>
                                <Setter TargetName="Handle" Property="Fill" Value="White"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HandleTransform" Storyboard.TargetProperty="X" To="18" Duration="0:0:0.1" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HandleTransform" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.1" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="#cccccc"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#000000"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3ea0f0"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#101010"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#1a1a1a" BorderBrush="#000000" BorderThickness="1">
        <Border BorderBrush="#3ea0f0" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" /> <!-- Title Bar -->
                    <RowDefinition Height="*" /> <!-- Features -->
                </Grid.RowDefinitions>

                <!-- Title bar -->
                <Grid Grid.Row="0" Background="#121212">
                    <Image Source="pack://application:,,,/icon.ico" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0,0,0" Width="16" Height="16" RenderOptions.BitmapScalingMode="HighQuality" />
                    
                    <TextBlock Text="Settings" Foreground="#cccccc" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Width="35" Background="Transparent" Foreground="#cccccc" BorderThickness="0" Content="—" Click="Minimize_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#333333"/></Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Width="35" Background="Transparent" Foreground="#cccccc" BorderThickness="0" Content="✕" Click="Close_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#e81123"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
                
                <!-- Separator Line -->
                <Border Grid.Row="0" VerticalAlignment="Bottom" Height="1" Background="#000000" />

                <!-- Settings Content List -->
                <StackPanel Grid.Row="1" Margin="15,15,5,15" WindowChrome.IsHitTestVisibleInChrome="True">
                    <CheckBox x:Name="ChkAutoAttach" Content="Auto Attach" Style="{StaticResource ToggleSwitch}" Margin="0,5" Checked="SettingChanged" Unchecked="SettingChanged"/>
                    <CheckBox x:Name="ChkTopMost" Content="Top Most" Style="{StaticResource ToggleSwitch}" Margin="0,5" Checked="SettingChanged" Unchecked="SettingChanged"/>
                    <CheckBox x:Name="ChkFadeEffects" Content="Opacity Fade-in/out" Style="{StaticResource ToggleSwitch}" Margin="0,5" Checked="SettingChanged" Unchecked="SettingChanged"/>
                    <CheckBox x:Name="ChkAutoExecute" Content="Auto Execute" Style="{StaticResource ToggleSwitch}" Margin="0,5" Checked="SettingChanged" Unchecked="SettingChanged"/>
                    
                    <Border Height="1" Background="#2a2a2a" Margin="0,8,10,8" />
                    
                    <CheckBox x:Name="ChkDiscordRPC" Content="Discord RPC" Style="{StaticResource ToggleSwitch}" Margin="0,5" Checked="SettingChanged" Unchecked="SettingChanged"/>
                    <CheckBox x:Name="ChkFpsUnlocker" Content="FPS Unlocker" Style="{StaticResource ToggleSwitch}" Margin="0,5" Checked="SettingChanged" Unchecked="SettingChanged"/>
                    
                    <Border Height="1" Background="#2a2a2a" Margin="0,8,10,8" />
                    
                    <Grid Margin="0,5,10,5">
                        <TextBlock Text="Run SirHurt Cleaner" Foreground="#dddddd" VerticalAlignment="Center" />
                        <Button Content="CLEAN" HorizontalAlignment="Right" Click="BtnCleaner_Click" />
                    </Grid>

                    <Grid Margin="0,5,10,5">
                        <TextBlock Text="Install missing files" Foreground="#dddddd" VerticalAlignment="Center" />
                        <Button Content="INSTALL" HorizontalAlignment="Right" Click="BtnInstall_Click" />
                    </Grid>

                    <Border Height="1" Background="#2a2a2a" Margin="0,8,10,8" />
                    
                    <StackPanel Margin="0,5,10,0">
                        <TextBlock x:Name="TxtAppVersion" Text="MossadStudio version: v1.0.0" Foreground="#555555" FontSize="10" />
                        <TextBlock x:Name="TxtSirHurtVersion" Text="SirHurt version: V5.xxx" Foreground="#555555" FontSize="10" />
                        <TextBlock x:Name="TxtRobloxVersion" Text="Roblox Client version: version-xxxxx" Foreground="#555555" FontSize="10" />
                    </StackPanel>

                </StackPanel>
            </Grid>
        </Border>
    </Border>
</Window>
