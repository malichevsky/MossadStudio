<Window x:Class="MossadStudio.GamesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RScripts Hub" Height="350" Width="650"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="CanResize" AllowsTransparency="True" Background="Transparent"
        FontFamily="Segoe UI" FontSize="12">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30" CornerRadius="0" GlassFrameThickness="0" ResizeBorderThickness="4" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Standard Button Style -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="#cccccc"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#000000"/>
            <Setter Property="Padding" Value="10,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#2f2f2f"/>
                                <Setter Property="Foreground" Value="#ffffff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom Dark ScrollBar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#121212"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#444444" CornerRadius="3" Margin="2" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#121212" BorderBrush="#000000" BorderThickness="1">
        <Border BorderBrush="#3ea0f0" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" />
                    <RowDefinition Height="50" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Title Bar -->
                <Grid Grid.Row="0" Background="#181818" WindowChrome.IsHitTestVisibleInChrome="False">
                    <Image Source="pack://application:,,,/icon.ico" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0,0,0" Width="16" Height="16" RenderOptions.BitmapScalingMode="HighQuality" />
                    
                    <TextBlock Text="Script Hub" Foreground="#aaaaaa" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Normal"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Content="&#xE921;" FontFamily="Segoe MDL2 Assets" Foreground="#888888" Background="Transparent" BorderThickness="0" FontSize="10" Width="40" Click="Minimize_Click" Cursor="Hand" />
                        <Button Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" Foreground="#888888" Background="Transparent" BorderThickness="0" FontSize="10" Width="40" Click="Close_Click" Cursor="Hand" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="0" BorderBrush="#000000" BorderThickness="0,0,0,1" />

                <!-- Search Bar -->
                <Grid Grid.Row="1" Background="#181818">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" Margin="10,10,5,10">
                        <TextBox x:Name="TxtSearch" Background="#222222" Foreground="#ffffff" BorderBrush="#333333" BorderThickness="1" VerticalContentAlignment="Center" Padding="5,0" TextChanged="TxtSearch_TextChanged"/>
                        <TextBlock x:Name="TxtSearchPlaceholder" IsHitTestVisible="False" Text="Search for a script. Powered by Rscripts.net" Foreground="#777777" FontStyle="Italic" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </Grid>
                    <Button Grid.Column="1" Content="SEARCH" Margin="5,10,10,10" Click="BtnSearch_Click"/>
                </Grid>

                <Border Grid.Row="1" BorderBrush="#000000" BorderThickness="0,0,0,1" />

                <!-- Content Grid -->
                <Grid Grid.Row="2" Background="#1c1c1c">
                    <ListBox x:Name="ScriptsList" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="{TemplateBinding Background}" BorderBrush="#333333" BorderThickness="0,0,0,1" Margin="5">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#222222" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <Border Grid.Column="0" Width="90" Height="50" CornerRadius="4" Background="#111111" ClipToBounds="True">
                                        <Image Source="{Binding image, IsAsync=True}" Stretch="UniformToFill" />
                                    </Border>
                                    
                                    <StackPanel Grid.Column="1" Margin="10,0">
                                        <TextBlock Text="{Binding title}" Foreground="#ffffff" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding description}" Foreground="#aaaaaa" FontSize="11" TextWrapping="Wrap" MaxHeight="32" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Center">
                                        <Button Content="OPEN TAB" Tag="{Binding .}" Margin="0,0,0,4" Click="BtnOpenScriptTab_Click" FontSize="10" Padding="5,2" />
                                        <Button Content="EXECUTE" Tag="{Binding rawScript}" Click="BtnExecuteScript_Click" FontSize="10" Padding="5,2" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Loading / Status Overlay -->
                    <Border x:Name="StatusOverlay" Background="#991c1c1c" Visibility="Collapsed">
                        <TextBlock x:Name="StatusText" Text="Loading Scripts..." Foreground="#ffffff" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
