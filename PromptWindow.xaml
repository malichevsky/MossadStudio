<Window x:Class="MossadStudio.PromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Prompt" Height="150" Width="300"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True" Background="Transparent"
        FontFamily="Segoe UI" FontSize="12" WindowStartupLocation="CenterOwner">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30" CornerRadius="0" GlassFrameThickness="0" ResizeBorderThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border Background="#1a1a1a" BorderBrush="#000000" BorderThickness="1">
        <Border BorderBrush="#3ea0f0" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" /> <!-- Title Bar -->
                    <RowDefinition Height="*" /> <!-- Content -->
                </Grid.RowDefinitions>

                <!-- Title bar -->
                <Grid Grid.Row="0" Background="#121212">
                    <TextBlock x:Name="TxtTitle" Text="Enter Value" Foreground="#cccccc" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Width="35" Background="Transparent" Foreground="#cccccc" BorderThickness="0" Content="✕" Click="Close_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#e81123"/><Setter Property="Foreground" Value="White"/></Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
                
                <Border Grid.Row="0" VerticalAlignment="Bottom" Height="1" Background="#000000" />

                <!-- Main Context -->
                <Grid Grid.Row="1" Background="#1c1c1c">
                    <Grid Margin="15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock x:Name="TxtMessage" Grid.Row="0" Foreground="#dddddd" Margin="0,0,0,10" Text="Message:" TextWrapping="Wrap"/>
                        
                        <TextBox x:Name="TxtInput" Grid.Row="1" Background="#222222" Foreground="#ffffff" BorderBrush="#333333" BorderThickness="1" Padding="5,2" Height="26" VerticalContentAlignment="Center" KeyDown="TxtInput_KeyDown" />
                        
                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                            <Button Content="Ok" Click="Ok_Click" Width="70" Background="#252525" Foreground="#cccccc" BorderThickness="1" BorderBrush="#000000" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/></Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#3ea0f0"/><Setter Property="Foreground" Value="White"/></Trigger>
                                                        <Trigger Property="IsPressed" Value="True"><Setter Property="Background" Value="#101010"/></Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
