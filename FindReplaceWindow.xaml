<Window x:Class="MossadStudio.FindReplaceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Find &amp; Replace" Height="220" Width="400"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True" Background="Transparent"
        FontFamily="Segoe UI" FontSize="12">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30" CornerRadius="0" GlassFrameThickness="0" ResizeBorderThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Standard Button Style -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="#cccccc"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#000000"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#2f2f2f"/>
                                <Setter Property="Foreground" Value="#ffffff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#121212" BorderBrush="#000000" BorderThickness="1">
        <Border BorderBrush="#3ea0f0" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Title Bar -->
                <Grid Grid.Row="0" Background="#181818" WindowChrome.IsHitTestVisibleInChrome="False">
                    <Image Source="pack://application:,,,/icon.ico" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0,0,0" Width="16" Height="16" RenderOptions.BitmapScalingMode="HighQuality" />
                    
                    <TextBlock Text="Find &amp; Replace" Foreground="#aaaaaa" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Normal"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" Foreground="#888888" Background="Transparent" BorderThickness="0" FontSize="10" Width="40" Click="Close_Click" Cursor="Hand" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="0" BorderBrush="#000000" BorderThickness="0,0,0,1" />

                <!-- Content Grid -->
                <Grid Grid.Row="1" Background="#1c1c1c">
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Find what:" Foreground="#cccccc" VerticalAlignment="Center" />
                        <TextBox x:Name="txtFind" Grid.Row="0" Grid.Column="1" Background="#222222" Foreground="#ffffff" BorderBrush="#333333" BorderThickness="1" Padding="5,2" Margin="0,0,0,15" VerticalContentAlignment="Center" Height="26"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Replace with:" Foreground="#cccccc" VerticalAlignment="Center" />
                        <TextBox x:Name="txtReplace" Grid.Row="1" Grid.Column="1" Background="#222222" Foreground="#ffffff" BorderBrush="#333333" BorderThickness="1" Padding="5,2" Margin="0,0,0,15" VerticalContentAlignment="Center" Height="26"/>

                        <CheckBox x:Name="chkMatchCase" Grid.Row="2" Grid.Column="1" Content="Match case" Foreground="#aaaaaa" Margin="0,0,0,15"/>

                        <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Find Next" Click="FindNext_Click" Margin="0,0,10,0"/>
                            <Button Content="Replace" Click="Replace_Click" Margin="0,0,10,0"/>
                            <Button Content="Replace All" Click="ReplaceAll_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
